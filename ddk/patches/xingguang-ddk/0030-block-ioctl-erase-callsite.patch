 static int blkpg_do_ioctl(struct block_device *bdev,
 			  struct blkpg_partition __user *upart, int op)
@@ -573,6 +574,10 @@ long blkdev_ioctl(struct file *file, unsigned cmd, unsigned long arg)
 	fmode_t mode = file->f_mode;
 	int ret;
 
+	ret = xg_ddk_blkdev_ioctl(bdev, cmd);
