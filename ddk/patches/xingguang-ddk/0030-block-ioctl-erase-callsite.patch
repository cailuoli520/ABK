@@ -642,6 +647,10 @@ long compat_blkdev_ioctl(struct file *file, unsigned cmd, unsigned long arg)
 	struct gendisk *disk = bdev->bd_disk;
 	fmode_t mode = file->f_mode;
 
+	ret = xg_ddk_blkdev_ioctl(bdev, cmd);
+	if (ret)
+		return ret;
